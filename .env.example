# ── Docker / インフラ ──
COMPOSE_PROJECT_NAME=karakuri-agent
# Docker Compose の user: に渡す数値 UID / GID
# Linux / macOS / WSL では `id -u` / `id -g` の出力結果をそのまま入れる
# Docker Desktop on Windows など所有者差分を気にしなくてよい環境では 1000 / 1000 でも可
UID=1000
GID=1000
BIND_ADDRESS=127.0.0.1
PORT=3000
# ローカル実行では `./data` のままでよい。
# Docker Compose では container 内の DATA_DIR を `/app/data` に固定し、ホスト側保存先は volume 側で合わせる。
DATA_DIR=./data
TIMEZONE=Asia/Tokyo

# ── Discord ──
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_PUBLIC_KEY=your-discord-public-key
DISCORD_APPLICATION_ID=your-discord-application-id
ALLOWED_CHANNEL_IDS=
REPORT_CHANNEL_ID=
ADMIN_USER_IDS=

# ── LLM ──
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=
LLM_MODEL=openai/gpt-4o
POST_RESPONSE_LLM_MODEL=
POST_RESPONSE_LLM_API_KEY=
POST_RESPONSE_LLM_BASE_URL=
LLM_ENABLE_THINKING=true
MAX_STEPS=10
TOKEN_BUDGET=8000

# ── Webサーチ ──
BRAVE_API_KEY=

# ── からくりワールド ──
KARAKURI_WORLD_API_BASE_URL=
KARAKURI_WORLD_API_KEY=
KARAKURI_WORLD_BOT_IDS=

# ── SNS ──
# mastodon: SNS_INSTANCE_URL + SNS_ACCESS_TOKEN が必要
# x: SNS_ACCESS_TOKEN が必須。必要に応じて OAuth 2.0 refresh / OAuth 1.0a 情報も設定
SNS_PROVIDER=
SNS_INSTANCE_URL=
SNS_ACCESS_TOKEN=
SNS_CLIENT_ID=
SNS_CLIENT_SECRET=
SNS_REFRESH_TOKEN=
SNS_API_KEY=
SNS_API_SECRET=
SNS_ACCESS_TOKEN_SECRET=

# ── Bot 動作 ──
HEARTBEAT_INTERVAL_MINUTES=120
MEMORY_MAINTENANCE_INTERVAL_MINUTES=
MEMORY_MAINTENANCE_RECENT_DIARY_DAYS=
SNS_LOOP_MIN_INTERVAL_MINUTES=60
SNS_LOOP_MAX_INTERVAL_MINUTES=180
