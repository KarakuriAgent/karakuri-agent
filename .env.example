DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_PUBLIC_KEY=your-discord-public-key
DISCORD_APPLICATION_ID=your-discord-application-id
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=
BRAVE_API_KEY=
KARAKURI_WORLD_API_BASE_URL=
KARAKURI_WORLD_API_KEY=
SNS_PROVIDER=
SNS_INSTANCE_URL=
SNS_ACCESS_TOKEN=
# Docker Compose の user: に渡す数値 UID / GID
# Linux / macOS / WSL では `id -u` / `id -g` の出力結果をそのまま入れる
# Docker Desktop on Windows など所有者差分を気にしなくてよい環境では 1000 / 1000 でも可
UID=
GID=
# ローカル実行では `./data` のままでよい。
# Docker Compose では container 内の DATA_DIR を `/app/data` に固定し、ホスト側保存先は volume 側で合わせる。
DATA_DIR=./data
TIMEZONE=Asia/Tokyo
LLM_MODEL=openai/gpt-4o
POST_RESPONSE_LLM_MODEL=
POST_RESPONSE_LLM_API_KEY=
POST_RESPONSE_LLM_BASE_URL=
MAX_STEPS=10
TOKEN_BUDGET=8000
PORT=3000
HEARTBEAT_INTERVAL_MINUTES=120
ALLOWED_CHANNEL_IDS=
REPORT_CHANNEL_ID=
ADMIN_USER_IDS=
KARAKURI_WORLD_BOT_IDS=
